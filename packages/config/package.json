{
  "name": "@axiom/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared configuration for the Axiom Protocol — env loader, network defaults, deployed addresses.",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./env": "./dist/env.js",
    "./networks": "./dist/networks.js",
    "./addresses": "./dist/addresses.js",
    "./types/hex": "./dist/types/hex.js",
    "./types/bigint": "./dist/types/bigint.js",
    "./types/schemas": "./dist/types/schemas.js",
    "./types/contract": "./dist/types/contract.js",
    "./abis": "./dist/abis/index.js",
    "./abis/agentNft": "./dist/abis/agentNft.js",
    "./abis/vault": "./dist/abis/vault.js",
    "./abis/paymentProcessor": "./dist/abis/paymentProcessor.js",
    "./abis/iTransferFrom": "./dist/abis/iTransferFrom.js",
    "./middleware/auth": "./dist/middleware/auth.js",
    "./env-schema": "./dist/env-schema.js",
    "./api": "./dist/api/index.js",
    "./storage/0g": "./dist/storage/0g.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.10",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "viem": "^2.21.45",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
