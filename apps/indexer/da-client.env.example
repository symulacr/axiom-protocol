# ─── 0G DA Client — Environment Variables ──────────────────────────────────
# Copy this file to da-client.env and fill in your values.
# Reference: https://github.com/0glabs/0g-da-client

# ─── gRPC Server ───────────────────────────────────────────────────────────
DA_GRPC_LISTEN_ADDRESS=0.0.0.0
DA_GRPC_LISTEN_PORT=51001
DA_GRPC_MAX_MESSAGE_SIZE=67108864
DA_GRPC_TLS_ENABLED=false

# ─── Chain Connection ──────────────────────────────────────────────────────
CHAIN_RPC_ENDPOINT=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602
PRIVATE_KEY=0x...
SIGNER_ADDRESS=0x...

# ─── BLS Signing ───────────────────────────────────────────────────────────
SIGNER_BLS_KEY=
SIGNER_BLS_KEY_PASSWORD=

# ─── DA Protocol ───────────────────────────────────────────────────────────
DA_ENTRANCE_ADDRESS=0x...
DA_SIGNERS_ADDRESS=0x...
QUORUM_ID=0
CONFIRM_DEPTH=12
CONFIRM_TIMEOUT=120s
CONFIRM_RETRY_INTERVAL=2s

# ─── Node ───────────────────────────────────────────────────────────────────
SOCKET_ADDRESS=
NODE_TIMEOUT=30s
TX_POOL_SIZE=100
TX_BACKOFF=1s
WORKER_COUNT=4
DATA_DIR=/data

# ─── Metrics ───────────────────────────────────────────────────────────────
ENABLE_METRICS=false
METRICS_PORT=9101

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
LOG_PATH=
