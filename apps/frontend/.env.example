# Local development environment variables for the Axiom Protocol frontend.
#
# Copy this file to `.env` (local only) and fill in the real values.
# Environment variables prefixed with `VITE_` are exposed to the browser
# by Vite at build time:
#   https://vitejs.dev/guide/env-and-mode
#
# For Vercel deploys use `.env.vercel` (see `.env.vercel.example`).

# Public URL of the Axiom backend HTTP API (no trailing slash).
# Default for local dev — the backend runs on port 3000.
VITE_BACKEND_URL=http://localhost:3000

# WalletConnect Cloud project ID. Required for RainbowKit v2 to enable
# the WalletConnect v2 transport; other connectors (Injected, MetaMask)
# still work without it but WalletConnect-based wallets will not appear
# in the modal. Get one at https://cloud.walletconnect.com.
# === WalletConnect ===
VITE_WALLETCONNECT_PROJECT_ID=6f1ffc664e99b8191fb043890110f173
