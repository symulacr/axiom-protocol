# Vercel environment variables for the Axiom Protocol frontend.
#
# Copy this file to `.env.vercel` (local only) and fill in the real values,
# or paste each line into the Vercel dashboard at
#   Project Settings -> Environment Variables
# and select the "Production" + "Preview" scopes.
#
# Anything the browser reads MUST be prefixed with `VITE_` (Vite's
# convention for client-exposed env vars — non-prefixed vars stay
# server-side and are NOT inlined into the bundle):
#   https://vitejs.dev/guide/env-and-mode
#
# Verifying after deploy:
#   curl -fsSL https://beta.axiom-protocol.xyz/ | grep -o 'Axiom Protocol'
# The three values below are the only ones Vercel needs to inject at
# build time. Secrets for the backend (DEPLOYER_PK, OG_RPC_URL, etc.) are
# set in Fly.io, not here.

# Public URL of the Axiom backend HTTP API (no trailing slash). The
# frontend hits `${VITE_BACKEND_URL}/v1/orchestrator/tick` and similar.
# Production: https://api.axiom-protocol.xyz
# Preview:    https://api-preview.axiom-protocol.xyz
VITE_BACKEND_URL=https://api.axiom-protocol.xyz

# WalletConnect Cloud project ID. Required for RainbowKit v2 to enable
# the WalletConnect v2 transport; other connectors (Injected, MetaMask)
# still work without it but WalletConnect-based wallets will not appear
# in the modal. Get one at https://cloud.walletconnect.com.
VITE_WALLETCONNECT_PROJECT_ID=00000000000000000000000000000000


