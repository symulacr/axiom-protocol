{
  "name": "@axiom/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Axiom Protocol orchestration engine + HTTP/WS server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "prestart": "pnpm build",
    "dev": "node --import tsx src/index.ts",
    "test": "node --import tsx --test src/**/*.test.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "pre-run-e2e": "pnpm --filter @axiom/oracle build && pnpm build",
    "run-e2e": "pnpm --filter @axiom/oracle build && pnpm build && node --import tsx src/cli/run-e2e.ts"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.10",
    "@axiom/config": "workspace:*",
    "@axiom/oracle": "workspace:*",
    "cors": "^2.8.6",
    "eciesjs": "^0.4.18",
    "ethereum-cryptography": "^2.2.1",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "openai": "^4.104.0",
    "viem": "^2.21.45",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
