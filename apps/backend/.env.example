# === Required ===
AXIOM_EVM_RPC=https://evmrpc-testnet.0g.ai
AXIOM_ORACLE_URL=http://127.0.0.1:8787
DEPLOYER_PK=0xabc123...   # backend signer wallet

# === Optional (defaults shown) ===
AXIOM_BIND=127.0.0.1
AXIOM_PORT=3000
AXIOM_STORAGE_RPC=https://indexer-storage-testnet-turbo.0g.ai
AXIOM_CHAIN_ID=16602
AXIOM_FRONTEND_URL=http://localhost:5173

# === 0G Compute ===
# Direct SDK auth token (app-sk-*) — PRIMARY. Generated by 0g-compute-cli.
#   Sends to https://compute-network-6.integratenetwork.work/v1/proxy (the
#   Direct SDK proxy).  Override the proxy URL with AXIOM_COMPUTE_BASE_URL.
AXIOM_COMPUTE_DIRECT_KEY=app-sk-...
# AXIOM_COMPUTE_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy
#
# Router API key (sk-*) — FALLBACK. Used when AXIOM_COMPUTE_DIRECT_KEY is unset.
# OG_COMPUTE_BASE_URL is consumed by apps/backend/src/compute/router.ts
# Precedence: AXIOM_COMPUTE_DIRECT_KEY > AXIOM_COMPUTE_API_KEY > OG_COMPUTE_API_KEY
# AXIOM_COMPUTE_API_KEY=sk-your-api-key
# OG_COMPUTE_API_KEY=sk-your-api-key

# === Oracle Storage (for oracle; unset both indexer+evm to use InMemoryStorage dev fallback) ===
# AXIOM_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# AXIOM_STORAGE_EVM_RPC=https://evmrpc-testnet.0g.ai
# AXIOM_STORAGE_PRIVATE_KEY=0x...   # separate key for storage gas (defaults to TEE_SIGNER_PK)

# === Contract addresses (testnet defaults) ===
# AGENT_NFT_ADDRESS=0xf12F158a20c36a351b056FD60b3a7377ce4F1e09
# VAULT_ADDRESS=0xb7F89e50D5A3039Da7d39528436B820371572874
# AXIOM_TEE_VERIFIER=0x24f725198d64A3b03A8386cD8fa12BD7c591734A
# PAYMENT_PROCESSOR_ADDRESS=0x096203fB54681b66dD8ab9bA47aaB462aA8C4A5f

