# Axiom Protocol — Environment Variables
#
# Copy this file to .env and fill in your values.

# ─── Backend ────────────────────────────────────────────────────────────────
AXIOM_EVM_RPC=https://evmrpc-testnet.0g.ai
AXIOM_ORACLE_URL=http://127.0.0.1:8787
AXIOM_CHAIN_ID=16602
AXIOM_TEE_SIGNER_PK=0x...
DEPLOYER_PK=0x...
AXIOM_COMPUTE_DIRECT_KEY=app-sk-...
# AXIOM_COMPUTE_API_KEY=sk-...                    # fallback when DIRECT_KEY unset
# AXIOM_COMPUTE_MODEL=qwen/qwen2.5-omni-7b

# Server
# AXIOM_BIND=127.0.0.1
# AXIOM_PORT=3000
# AXIOM_FRONTEND_URL=http://localhost:5173

# Optional API key for bearer-token auth on HTTP endpoints
# AXIOM_API_KEY=sk-...

# Compute Router overrides
# OG_COMPUTE_BASE_URL=https://router-api-testnet.integratenetwork.work/v1   # explicit Router base URL
# AXIOM_COMPUTE_BASE_URL=https://compute-network-6.integratenetwork.work/v1/proxy  # Direct SDK proxy base URL
# OG_COMPUTE_API_KEY=sk-...                          # fallback Router API key (when AXIOM_COMPUTE_API_KEY unset)

# Storage
# AXIOM_STORAGE_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Contract addresses (testnet defaults)
# AGENT_NFT_ADDRESS=0xf12F158a20c36a351b056FD60b3a7377ce4F1e09
# VAULT_ADDRESS=0xb7F89e50D5A3039Da7d39528436B820371572874
# AXIOM_TEE_VERIFIER=0x24f725198d64A3b03A8386cD8fa12BD7c591734A
# PAYMENT_PROCESSOR_ADDRESS=0x096203fB54681b66dD8ab9bA47aaB462aA8C4A5f

# ─── Oracle ─────────────────────────────────────────────────────────────────
# (shares AXIOM_TEE_SIGNER_PK, AXIOM_EVM_RPC, AXIOM_CHAIN_ID from above)
# AXIOM_ORACLE_PORT=8787
# AXIOM_ORACLE_BIND=127.0.0.1
# AXIOM_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# AXIOM_STORAGE_EVM_RPC=https://evmrpc-testnet.0g.ai
# AXIOM_STORAGE_PRIVATE_KEY=0x...                 # defaults to TEE_SIGNER_PK

# ─── Indexer ────────────────────────────────────────────────────────────────
OG_RPC_URL=https://evmrpc-testnet.0g.ai
BACKEND_URL=http://127.0.0.1:3000
# OG_CHAIN_ID=16602
DA_GRPC_URL=localhost:51001
# INDEXER_DA_ENABLED=false                           # gate DA submitter (0G Storage / gRPC)
# STORAGE_BATCH_INTERVAL_MS=5000                     # event batch upload interval
# STORAGE_BATCH_MAX_EVENTS=10                        # max events per batch upload

# ─── Frontend (prefixed with VITE_) ─────────────────────────────────────────
VITE_BACKEND_URL=http://127.0.0.1:3000
VITE_WALLETCONNECT_PROJECT_ID=
