{
  "outputDirectory": "apps/frontend/dist",
  "buildCommand": "pnpm --filter @axiom/config build && pnpm --filter @axiom/frontend build",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
