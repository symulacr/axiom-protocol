flowchart TB
    %% Axiom Protocol — High-Level Architecture
    %% Source: https://docs.0g.ai/ai-context + https://github.com/0gfoundation/0g-agent-nft

    User([User with<br/>MetaMask / RainbowKit])
    Frontend["Frontend (apps/frontend)<br/>Vite + React 18 + wagmi + RainbowKit<br/>Vercel static site"]
    Backend["Backend (apps/backend)<br/>Node 22 + Express + WS<br/>Fly.io long-lived process"]
    Oracle["TEE Signer Service (apps/oracle)<br/>Node 22 + AES-256-GCM + ECIES<br/>Fly.io long-lived process ⚠️ simulated"]
    Indexer["Indexer (apps/indexer)<br/>Node 22 + viem.watchEvent<br/>Fly.io with 0G DA Client sidecar"]

    NFT[AxiomAgentNFT<br/>ERC-7857 UUPS<br/>on 0G Chain]
    Vault[AxiomStrategyVault<br/>on 0G Chain]
    PayProc[AxiomPaymentProcessor<br/>on 0G Chain]
    Verifier[AxiomTeeVerifier<br/>on 0G Chain]

    Storage["0G Storage<br/>@0gfoundation/0g-ts-sdk<br/>Client-side AES-256-GCM<br/>Turbo indexer: indexer-storage-testnet-turbo.0g.ai"]
    Compute["0G Compute<br/>@0gfoundation/0g-compute-ts-sdk<br/>Broker + Router<br/>TeeML attestation"]
    Chain["0G Chain<br/>Galileo (chainId 16602)<br/>Aristotle (chainId 16661)"]
    DA["0G DA ⏳ planned<br/>Docker gRPC port 51001<br/>32 MB blob cap<br/>DAEntrance 0xE75A...957B"]

    %% Frontend flow
    User -->|"wallet<br/>sign"| Frontend
    Frontend -->|"HTTP/WS API"| Backend

    %% Backend orchestration
    Backend -->|"getServiceMetadata<br/>depositFund<br/>acknowledgeProvider"| Compute
    Backend -->|"chat completions<br/>(signed)"| Compute
    Backend -->|"upload JSON<br/>downloadToBlob"| Storage
    Backend -->|"iTransferFrom<br/>setStrategy<br/>deposit<br/>execute"| Chain

    %% Oracle (TEE signer) flow
    Backend -->|"transfer-validity<br/>(signed payload)"| Oracle
    Oracle -->|"OwnershipProof.signature"| Backend
    Oracle -->|"decrypt blob<br/>re-encrypt<br/>upload"| Storage

    %% Indexer flow
    Indexer -->|"watchEvent"| Chain
    Indexer -->|"DisperseBlob<br/>(gRPC)"| DA
    Indexer -->|"GET proof<br/>(HTTP)"| DA

    %% Chain sub-graph
    Chain --> NFT
    Chain --> Vault
    Chain --> PayProc
    Chain --> Verifier

    %% Notes
    Note1["Frontend: Vercel static only<br/>Backend/Oracle/Indexer: Fly.io persistent<br/>No long-lived state on Vercel<br/>VITE_ prefix for browser vars"]
    Note1 -.-> Frontend
    Note1 -.-> Backend
    Note1 -.-> Oracle
    Note1 -.-> Indexer

    %% Legend for devnet/production annotations
    Legend["Status annotations:<br/>⚠️ simulated (devnet mode, software signer)<br/>⏳ planned (not yet wired in this wave)"]
    Legend -.-> Oracle
    Legend -.-> DA

